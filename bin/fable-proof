#!/usr/bin/env bash
#
# fable-proof — FWM Stage 2: the both-directions harness (Move 3 / FWM-1).
#
# Given a check command and two fixture directories, runs the check inside
# each and demands opposite outcomes:
#
#   should-pass/  -> check must exit 0
#   should-fail/  -> check must exit non-zero
#
# Verdicts:
#   PROVEN    pass-case passed AND fail-case failed          (exit 0)
#   UNPROVEN  a direction could not be demonstrated/run      (exit 1)
#   BROKEN    pass-case failed, or fail-case passed          (exit 1)
#
# The core rule encoded here: a check that has only ever passed is unproven.
# This harness will not say PROVEN without a demonstrated failure.
#
# Usage:
#   fable-proof --check '<command>' --fixtures <dir>
#     where <dir> contains should-pass/ and should-fail/
#   The command runs with CWD set to each fixture directory.
#
# Writes: nothing outside the fixture directories themselves (the check
# command may write inside its fixture CWD; the harness itself writes only
# to stdout/stderr and a temp log under $TMPDIR).
#
# Spec: .fable/BUILD.md §2 Stage 2.
#
set -euo pipefail

if [ -t 1 ]; then
  RED=$'\033[31m'; GREEN=$'\033[32m'; YELLOW=$'\033[33m'; BOLD=$'\033[1m'; RESET=$'\033[0m'
else
  RED=""; GREEN=""; YELLOW=""; BOLD=""; RESET=""
fi

CHECK=""
FIXTURES=""
while [ $# -gt 0 ]; do
  case "$1" in
    --check)    CHECK="${2:-}"; shift 2 ;;
    --fixtures) FIXTURES="${2:-}"; shift 2 ;;
    -h|--help)  sed -n '2,28p' "$0" | sed 's/^# \{0,1\}//'; exit 0 ;;
    *) printf 'Unknown argument: %s\n' "$1" >&2; exit 2 ;;
  esac
done

if [ -z "$CHECK" ] || [ -z "$FIXTURES" ]; then
  printf 'Usage: fable-proof --check <command> --fixtures <dir>\n' >&2
  exit 2
fi

PASS_DIR="$FIXTURES/should-pass"
FAIL_DIR="$FIXTURES/should-fail"

printf '%s=== fable-proof ===%s\n' "$BOLD" "$RESET"
printf 'check    : %s\n' "$CHECK"
printf 'fixtures : %s\n\n' "$FIXTURES"

verdict() {
  # $1 = verdict word, $2 = explanation, $3 = exit code
  case "$1" in
    PROVEN)   printf '\n%s%sVERDICT: PROVEN%s — %s\n' "$BOLD" "$GREEN" "$RESET" "$2" ;;
    UNPROVEN) printf '\n%s%sVERDICT: UNPROVEN%s — %s\n' "$BOLD" "$YELLOW" "$RESET" "$2" ;;
    BROKEN)   printf '\n%s%sVERDICT: BROKEN%s — %s\n' "$BOLD" "$RED" "$RESET" "$2" ;;
  esac
  exit "$3"
}

[ -d "$PASS_DIR" ] || verdict UNPROVEN "fixture '$PASS_DIR' does not exist; the pass direction cannot be demonstrated" 1
[ -d "$FAIL_DIR" ] || verdict UNPROVEN "fixture '$FAIL_DIR' does not exist; the fail direction cannot be demonstrated" 1

LOG=$(mktemp "${TMPDIR:-/tmp}/fable-proof.XXXXXX")
trap 'rm -f "$LOG"' EXIT

run_in() {
  # $1 = dir; returns the check's exit code, output captured to $LOG
  ( cd "$1" && eval "$CHECK" ) >"$LOG" 2>&1 && return 0 || return $?
}

# Direction 1: should-pass
PASS_EXIT=0
run_in "$PASS_DIR" || PASS_EXIT=$?
if [ "$PASS_EXIT" = 0 ]; then
  PASS_OK=1
  printf '[pass-case] %sexit 0%s in should-pass/ — as required\n' "$GREEN" "$RESET"
else
  PASS_OK=0
  printf '[pass-case] %sexit %s%s in should-pass/ — check failed its clean case\n' "$RED" "$PASS_EXIT" "$RESET"
  sed 's/^/            /' "$LOG" | tail -10
fi

# Direction 2: should-fail
FAIL_EXIT=0
run_in "$FAIL_DIR" || FAIL_EXIT=$?
if [ "$FAIL_EXIT" = 0 ]; then
  FAIL_OK=0
  printf '[fail-case] %sexit 0%s in should-fail/ — check passed a case built to fail\n' "$RED" "$RESET"
else
  FAIL_OK=1
  printf '[fail-case] %sexit %s%s in should-fail/ — as required\n' "$GREEN" "$FAIL_EXIT" "$RESET"
fi

if [ "$PASS_OK" = 1 ] && [ "$FAIL_OK" = 1 ]; then
  verdict PROVEN "both directions demonstrated" 0
elif [ "$PASS_OK" = 0 ] && [ "$FAIL_OK" = 1 ]; then
  verdict BROKEN "check rejects its own clean case" 1
elif [ "$PASS_OK" = 1 ] && [ "$FAIL_OK" = 0 ]; then
  verdict BROKEN "check cannot detect the violation it exists to catch" 1
else
  verdict BROKEN "check fails clean input AND passes bad input — it measures nothing" 1
fi
