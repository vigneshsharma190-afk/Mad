#!/usr/bin/env bash
#
# fable-claim — FWM Stage 4: the smallest true claim (Move 5 / FWM-3).
#
# Assembles a completion report from MECHANICAL sources only. Nothing in the
# VERIFIED section is asserted by judgment; every line is the output of a
# command run right now. Anything not mechanically confirmable lands in
# UNVERIFIED/OPEN — visibly, never omitted. This makes completion pressure
# (FWM §3.5) impossible to indulge: the tool cannot say "done" early because
# it does not know how to say anything it did not measure.
#
# Usage:
#   fable-claim [--base <ref>]     # report on work since <ref> (default:
#                                  # origin/<default branch>, else HEAD)
#
# Read-only. Exit codes:
#   0  report produced (the report itself may list open/unverified items —
#      exit 0 means "true report", not "task complete")
#   2  environment cannot be inspected
#
# Spec: .fable/BUILD.md §2 Stage 4.
#
set -euo pipefail

if [ -t 1 ]; then
  BOLD=$'\033[1m'; DIM=$'\033[2m'; YELLOW=$'\033[33m'; RESET=$'\033[0m'
else
  BOLD=""; DIM=""; YELLOW=""; RESET=""
fi

BASE_ARG=""
while [ $# -gt 0 ]; do
  case "$1" in
    --base) BASE_ARG="${2:-}"; shift 2 ;;
    -h|--help) sed -n '2,22p' "$0" | sed 's/^# \{0,1\}//'; exit 0 ;;
    *) printf 'Unknown argument: %s\n' "$1" >&2; exit 2 ;;
  esac
done

REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null) || {
  printf 'UNVERIFIABLE — not a git repository; no claim can be assembled.\n'
  exit 2
}
cd "$REPO_ROOT"
git rev-parse --verify HEAD >/dev/null 2>&1 || {
  printf 'UNVERIFIABLE — no commits; no claim can be assembled.\n'
  exit 2
}

if [ -n "$BASE_ARG" ]; then
  BASE="$BASE_ARG"
elif DEFAULT=$(git symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null); then
  BASE="$DEFAULT"
elif git rev-parse --verify origin/main >/dev/null 2>&1; then
  BASE="origin/main"
else
  BASE="HEAD"
fi
git rev-parse --verify "$BASE" >/dev/null 2>&1 || {
  printf 'UNVERIFIABLE — base ref "%s" does not resolve.\n' "$BASE"
  exit 2
}

printf '%s=== fable-claim ===%s\n' "$BOLD" "$RESET"
printf 'base: %s   head: %s   generated by mechanical inspection only\n' \
  "$BASE" "$(git rev-parse --short HEAD)"

# ---------------------------------------------------------------------------
printf '\n%s-- VERIFIED (each line is command output, not judgment) --%s\n' "$BOLD" "$RESET"

printf '\n[what changed] git diff --stat %s..HEAD\n' "$BASE"
DIFFSTAT=$(git diff --stat "$BASE"..HEAD -- 2>/dev/null || true)
if [ -n "$DIFFSTAT" ]; then
  printf '%s\n' "$DIFFSTAT" | sed 's/^/  /'
else
  printf '  (no committed changes vs %s)\n' "$BASE"
fi

printf '\n[gates run now, exit codes verbatim]\n'
if [ -x bin/moe-verify.sh ]; then
  MOE_EXIT=0; ./bin/moe-verify.sh >/tmp/fable-claim-moe.log 2>&1 || MOE_EXIT=$?
  printf '  moe-verify.sh (diff mode)  -> exit %s\n' "$MOE_EXIT"
else
  printf '  moe-verify.sh              -> not present/executable\n'
fi
if [ -x bin/fable-preflight ]; then
  PF_EXIT=0; ./bin/fable-preflight >/tmp/fable-claim-pf.log 2>&1 || PF_EXIT=$?
  printf '  fable-preflight            -> exit %s\n' "$PF_EXIT"
fi

# ---------------------------------------------------------------------------
printf '\n%s-- OPEN / UNVERIFIED (named, never omitted) --%s\n' "$BOLD" "$RESET"
OPEN_COUNT=0

DIRTY=$(git status --porcelain)
if [ -n "$DIRTY" ]; then
  OPEN_COUNT=$((OPEN_COUNT + 1))
  printf '%s[open]%s uncommitted changes in working tree:\n' "$YELLOW" "$RESET"
  printf '%s\n' "$DIRTY" | sed 's/^/  /'
fi

BRANCH=$(git branch --show-current)
if [ -n "$BRANCH" ]; then
  if git ls-remote --exit-code origin "refs/heads/$BRANCH" >/dev/null 2>&1; then
    AHEAD=$(git rev-list --count "origin/$BRANCH..HEAD" 2>/dev/null || echo "?")
    if [ "$AHEAD" != "0" ]; then
      OPEN_COUNT=$((OPEN_COUNT + 1))
      printf '%s[open]%s %s commit(s) not pushed to origin/%s\n' "$YELLOW" "$RESET" "$AHEAD" "$BRANCH"
    fi
  elif git ls-remote origin HEAD >/dev/null 2>&1; then
    OPEN_COUNT=$((OPEN_COUNT + 1))
    printf '%s[open]%s branch %s exists only locally (never pushed)\n' "$YELLOW" "$RESET" "$BRANCH"
  else
    OPEN_COUNT=$((OPEN_COUNT + 1))
    printf '%s[unverified]%s push state — origin unreachable\n' "$YELLOW" "$RESET"
  fi
fi

TODOS=$(git diff "$BASE"..HEAD -- 2>/dev/null | grep -E '^\+.*(TODO|FIXME|XXX)\b' || true)
if [ -n "$TODOS" ]; then
  OPEN_COUNT=$((OPEN_COUNT + 1))
  printf '%s[open]%s TODO/FIXME markers introduced by this work:\n' "$YELLOW" "$RESET"
  printf '%s\n' "$TODOS" | sed 's/^/  /' | head -5
fi

if command -v gh >/dev/null 2>&1; then
  if PRS=$(gh pr list --state open --json number,title --jq '.[] | "#\(.number) \(.title)"' 2>/dev/null); then
    if [ -n "$PRS" ]; then
      OPEN_COUNT=$((OPEN_COUNT + 1))
      printf '%s[open]%s unmerged PR(s):\n' "$YELLOW" "$RESET"
      printf '%s\n' "$PRS" | sed 's/^/  /'
    fi
  else
    OPEN_COUNT=$((OPEN_COUNT + 1))
    printf '%s[unverified]%s open-PR state — gh query failed\n' "$YELLOW" "$RESET"
  fi
else
  OPEN_COUNT=$((OPEN_COUNT + 1))
  printf '%s[unverified]%s open-PR state — gh CLI unavailable\n' "$YELLOW" "$RESET"
fi

# ---------------------------------------------------------------------------
printf '\n%s-- CLAIM --%s\n' "$BOLD" "$RESET"
if [ "$OPEN_COUNT" = 0 ]; then
  printf 'All mechanically checkable state is settled: tree clean, work pushed,\n'
  printf 'no open PRs, no introduced TODOs, gate exit codes printed above.\n'
  printf '%sNote:%s this claims settled state, not semantic correctness — only\n' "$DIM" "$RESET"
  printf '%sthe gates above and human review can speak to that.%s\n' "$DIM" "$RESET"
else
  printf 'NOT settled: %s open/unverified item(s) listed above.\n' "$OPEN_COUNT"
  printf 'The smallest true claim is the report above — nothing more.\n'
fi
exit 0
